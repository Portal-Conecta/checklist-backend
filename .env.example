# Obrigatorio para builds locais via Maven (mvn/IDE) fora do Docker: .mvn/settings.xml
# le essas variaveis do ambiente para autenticar no GitHub Packages e baixar a lib
# privada com.portal.conecta:portal-logging. Sem elas, `mvn test`/`mvn install`
# falham na resolucao de dependencias.
# MAVEN_USERNAME = seu usuario do GitHub
# MAVEN_PASSWORD = um Personal Access Token (classic) com escopo `read:packages`
MAVEN_USERNAME=
MAVEN_PASSWORD=

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8083

DB_HOST=localhost
DB_PORT=5433
DB_NAME=checklist_db
DB_USER=checklist_user
DB_PASSWORD=checklist_password

# Obrigatorio: use o segredo Base64 HS256 configurado no Hub local. Nunca versione este valor.
JWT_SECRET=
HUB_API_URL=http://localhost:8080

RABBITMQ_ENABLED=true
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_NOTIFICATIONS_EXCHANGE=notifications.exchange
RABBITMQ_NOTIFICATIONS_QUEUE=notifications.dispatch.q
RABBITMQ_NOTIFICATIONS_DLQ=notifications.dispatch.dlq
RABBITMQ_NOTIFICATIONS_ROUTING_KEY=notification.requested
